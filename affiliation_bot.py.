def score_deal(deal):
score = 0
d = deal[“discount_pct”]
if d >= 70:    score += 50
elif d >= 60:  score += 40
elif d >= 50:  score += 30
else:          score += 20

```
s = deal["savings"]
if s >= 200:   score += 30
elif s >= 100: score += 20
elif s >= 50:  score += 10
elif s >= 20:  score += 5

try:
    r = float(deal.get("rating","0").replace(",","."))
    if r >= 4.5: score += 10
    elif r >= 4: score += 5
except: pass

return score
