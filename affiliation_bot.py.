```
    soup  = BeautifulSoup(r.text, "html.parser")
    items = soup.select("[data-component-type='s-search-result']")

    for item in items[:10]:
        try:
            # Titre
            title_el = item.select_one("h2 a span")
            if not title_el: continue
            title = title_el.get_text(strip=True)

            # ASIN — clé pour construire le lien direct produit
            asin = item.get("data-asin", "")
            if not asin: continue

            # Lien direct vers la page produit avec tag affilié
            product_url = build_amazon_link(asin)

            # Prix actuel
            price_el = item.select_one(".a-price .a-offscreen")
            if not price_el: continue
            price_str = price_el.get_text(strip=True)
            price_match = re.search(r'[\d,]+', price_str.replace(".", "").replace(",", "."))
            if not price_match: continue
            price = float(price_str.replace("€","").replace(" ","").replace(",",".").split()[0])

            # Prix original barré
            old_el = item.select_one(".a-price.a-text-price .a-offscreen")
            if not old_el: continue
            old_price = float(old_el.get_text(strip=True).replace("€","").replace(" ","").replace(",",".").split()[0])

            if old_price <= price or old_price == 0: continue
            disc = int((old_price - price) / old_price * 100)
            if disc < MIN_DISCOUNT_PCT: continue

            # Image du produit
            img_el  = item.select_one(".s-image")
            img_url = img_el.get("src", "") if img_el else ""

            # Note et avis
            rating_el  = item.select_one(".a-icon-star-small .a-icon-alt")
            reviews_el = item.select_one("[aria-label*='étoiles'] + span")
            rating     = rating_el.get_text(strip=True)[:3] if rating_el else "?"
            reviews    = reviews_el.get_text(strip=True) if reviews_el else "?"

            deals.append({
                "source":       "Amazon",
                "emoji":        "🟠",
                "title":        title[:80],
                "asin":         asin,
                "price":        price,
                "old_price":    old_price,
                "discount_pct": disc,
                "savings":      round(old_price - price, 2),
                "link":         product_url,  # Lien direct produit + tag affilié
                "img_url":      img_url,
                "rating":       rating,
                "reviews":      reviews,
            })
        except:
            continue

    time.sleep(random.uniform(2.0, 3.5))
except Exception as e:
    print(f"  [Amazon] Erreur '{keyword}': {e}")
return deals
```

